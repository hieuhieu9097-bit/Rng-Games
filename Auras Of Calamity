-- XỬ LÝ VÒNG LẶP HỆ THỐNG GOM VÀ THÔNG SỐ PLAYER
local function fastFirePrompt(prompt)
    if prompt and prompt:IsA("ProximityPrompt") then
        task.spawn(function()
            prompt.HoldDuration = 0
            fireproximityprompt(prompt)
            prompt:InputHoldBegin()
            prompt:InputHoldEnd()
        end)
    end
end

local function isPromptAllowed(prompt)
    local parentPart = prompt.Parent
    if not parentPart or not parentPart:IsA("BasePart") then return false end
    local name = string.lower(parentPart.Name)
    local states = _G.DeltaToggleStates
    
    if states.Coin and string.find(name, "coin") then
        if not parentPart:IsDescendantOf(workspace:FindFirstChild("Collectables")) then return true end
    end
    if states.Item and string.find(name, "cframe") then return true end
    if states.Star and prompt:IsDescendantOf(workspace:FindFirstChild("Debris")) then
        if not string.find(string.lower(parentPart.Parent.Name), "present") then return true end
    end
    if states.Present then
        local grandParent = parentPart.Parent
        if grandParent and string.find(string.lower(grandParent.Name), "present") and prompt:IsDescendantOf(workspace:FindFirstChild("Debris")) then return true end
    end
    return false
end

local function sweepEntireZone(centerPosition)
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and isPromptAllowed(v) then
            local parentPart = v.Parent
            if parentPart and parentPart:IsA("BasePart") then
                local dist = (parentPart.Position - centerPosition).Magnitude
                if dist <= 35 then fastFirePrompt(v) end
            end
        end
    end
end

local function getAllActiveTargets()
    local list = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and isPromptAllowed(v) then table.insert(list, v) end
    end
    return list
end

