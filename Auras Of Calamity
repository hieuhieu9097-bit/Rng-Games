local function GetPlaceCFrame(placeName)
    local targetCFrame = nil
    pcall(function()
        local rawObject = nil
        if placeName == "Workshop" then
            rawObject = workspace:FindFirstChild("Prompts") and workspace.Prompts:FindFirstChild("Shop")
        elseif placeName == "Title Shop" then
            rawObject = workspace:FindFirstChild("Prompts") and workspace.Prompts:FindFirstChild("TitleShop")
        elseif placeName == "Crafting Bar" then
            rawObject = workspace:FindFirstChild("Prompts") and workspace.Prompts:FindFirstChild("Potions")
        end
        
        if rawObject then
            if rawObject:IsA("BasePart") then
                targetCFrame = rawObject.CFrame
            else
                local fallback = rawObject:FindFirstChildWhichIsA("BasePart", true)
                if fallback then targetCFrame = fallback.CFrame end
            end
        end
    end)
    return targetCFrame
end

local function RemoveESP(item)
    if _G.ActiveESPObjects[item] then
        if _G.ActiveESPObjects[item].Highlight then pcall(function() _G.ActiveESPObjects[item].Highlight:Destroy() end) end
        if _G.ActiveESPObjects[item].Billboard then pcall(function() _G.ActiveESPObjects[item].Billboard:Destroy() end) end
        _G.ActiveESPObjects[item] = nil
    end
end

local function ApplyESP(item, customColor)
    if not item or not item.Parent then return end
    if _G.ActiveESPObjects[item] then return end 
    
    local referencePart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart", true)
    if not referencePart then return end
    
    local espData = {}
    local glowColor = customColor or Color3.fromRGB(0, 255, 127)
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "FortunaX_ESP_Glow"
    highlight.FillColor = glowColor
    highlight.FillTransparency = 0.4
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0
    highlight.Adornee = item
    highlight.Parent = item
    espData.Highlight = highlight
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "FortunaX_ESP_Tag"
    billboard.Size = UDim2.new(0, 150, 0, 40)
    billboard.AlwaysOnTop = true
    billboard.ExtentsOffset = Vector3.new(0, 3, 0)
    billboard.Adornee = referencePart
    billboard.Parent = referencePart
    espData.Billboard = billboard
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextColor3 = glowColor
    textLabel.TextSize = 10
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.Text = item.Name .. " [0m]"
    textLabel.Parent = billboard
    
    task.spawn(function()
        while item and item.Parent and referencePart and referencePart.Parent do
            local shouldStay = false
            if item.Name == "Fragment" and _G.DeltaToggleStates.ESPFragment then
                shouldStay = true
            elseif item.Name ~= "Fragment" and _G.DeltaToggleStates.ESP then
                shouldStay = true
            end
            
            if not shouldStay then break end
            
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = math.floor((referencePart.Position - root.Position).Magnitude)
                textLabel.Text = item.Name .. " [" .. dist .. "m]"
            end
            task.wait(0.2)
        end
        RemoveESP(item)
    end)
    
    _G.ActiveESPObjects[item] = espData
end

local function UpdateESPState()
    local collectablesFolder = workspace:FindFirstChild("Collectables")
    
    if _G.DeltaToggleStates.ESP and collectablesFolder then
        for _, name in ipairs(DiscoveredItemNames) do
            local item = collectablesFolder:FindFirstChild(name)
            if item then ApplyESP(item, Color3.fromRGB(0, 255, 127)) end
        end
    end
    
    if _G.DeltaToggleStates.ESPFragment then
        for _, child in ipairs(workspace:GetDescendants()) do
            if child.Name == "Fragment" then
                ApplyESP(child, Color3.fromRGB(255, 100, 255))
            end
        end
    end
end

local function ApplySuperFixLag(state)
    _G.DeltaToggleStates.FixLag = state
    if not state then return end
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name == "Grass" or obj.Name == "Plant" or obj.Name == "CLOUDS") then
            pcall(function() obj:Destroy() end)
        end
    end
    
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        MaterialService.Use2022Materials = false
        
        for _, effect in ipairs(Lighting:GetChildren()) do
            if effect:IsA("PostEffect") or effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("SunRaysEffect") or effect:IsA("ColorCorrectionEffect") then
                effect.Enabled = false
            end
        end
    end)
    
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("Texture") or desc:IsA("Decal") then
            pcall(function() desc:Destroy() end)
        elseif desc:IsA("BasePart") and not desc:IsA("MeshPart") then
            desc.Material = Enum.Material.SmoothPlastic
            desc.Reflectance = 0
        elseif desc:IsA("MeshPart") then
            desc.Material = Enum.Material.SmoothPlastic
            desc.Reflectance = 0
        end
    end
end

