-- VÒNG LẶP CORE CHẠY NGẦM ĐỊNH KỲ VĨNH VIỄN
-- ==========================================
local function fastFirePrompt(prompt)
    if prompt and prompt:IsA("ProximityPrompt") then
        task.spawn(function()
            prompt.HoldDuration = 0
            fireproximityprompt(prompt)
            prompt:InputHoldBegin()
            prompt:InputHoldEnd()
        end)
    end
end

local function isPromptAllowed(prompt)
    local parentPart = prompt.Parent
    if not parentPart or not parentPart:IsA("BasePart") then return false end
    local name = string.lower(parentPart.Name)
    local states = _G.DeltaToggleStates
    
    if states.Coin and string.find(name, "coin") then
        if not parentPart:IsDescendantOf(workspace:FindFirstChild("Collectables")) then return true end
    end
    if states.Item and string.find(name, "cframe") then return true end
    if states.Star and prompt:IsDescendantOf(workspace:FindFirstChild("Debris")) then
        if not string.find(string.lower(parentPart.Parent.Name), "present") then return true end
    end
    if states.Present then
        local grandParent = parentPart.Parent
        if grandParent and string.find(string.lower(grandParent.Name), "present") and prompt:IsDescendantOf(workspace:FindFirstChild("Debris")) then return true end
    end
    return false
end

local function sweepEntireZone(centerPosition)
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and isPromptAllowed(v) then
            local parentPart = v.Parent
            if parentPart and parentPart:IsA("BasePart") then
                local dist = (parentPart.Position - centerPosition).Magnitude
                if dist <= 35 then fastFirePrompt(v) end
            end
        end
    end
end

local function getAllActiveTargets()
    local list = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and isPromptAllowed(v) then table.insert(list, v) end
    end
    return list
end

if _G.CoreLoopActive == nil then
    _G.CoreLoopActive = true
    
    local collectablesFolder = workspace:WaitForChild("Collectables", 10)
    if collectablesFolder then
        collectablesFolder.ChildAdded:Connect(function(child)
            task.wait(0.2)
            if _G.DeltaToggleStates.ESP and table.find(DiscoveredItemNames, child.Name) then ApplyESP(child, Color3.fromRGB(0, 255, 127)) end
        end)
        collectablesFolder.ChildRemoved:Connect(function(child) RemoveESP(child) end)
    end

    workspace.DescendantAdded:Connect(function(descendant)
        if descendant.Name == "Fragment" and _G.DeltaToggleStates.ESPFragment then
            task.wait(0.2)
            ApplyESP(descendant, Color3.fromRGB(255, 100, 255))
        end
    end)

    task.spawn(function()
        while true do
            task.wait(0.05)
            local states = _G.DeltaToggleStates
            
            if states and (states.Coin or states.Item or states.Star or states.Present) then
                local allTargets = getAllActiveTargets()
                if #allTargets > 0 then
                    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if root and root.Parent then
                        local primaryPrompt = allTargets[1]
                        local targetPart = primaryPrompt.Parent
                        if targetPart and targetPart:IsA("BasePart") then
                            for i = 1, 5 do
                                if targetPart and targetPart.Parent then
                                    root.CFrame = targetPart.CFrame
                                    fastFirePrompt(primaryPrompt)
                                    sweepEntireZone(targetPart.Position)
                                end
                                task.wait(0.01)
                            end
                        end
                    end
                end
            end
            
            if states and (states.ESP or states.ESPFragment) then
                UpdateESPState()
                task.wait(1.5)
            end
        end
    end)
    
    LocalPlayer.Idled:Connect(function()
        pcall(function()
            VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            task.wait(1)
            VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        end)
    end)
end
